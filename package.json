{
  "name": "@narada2/agent-cli",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "narada-agent-cli": "./bin/narada-agent-cli.mjs"
  },
  "narada": {
    "package_role": "nars_client_projection",
    "runtime_server_owner": "@narada2/agent-runtime-server"
  },
  "exports": {
    ".": "./src/agent-cli.mjs",
    "./nars-attach-client": "./src/nars-attach-client.mjs",
    "./projected-terminal": "./src/projected-terminal.mjs",
    "./runtime-server-events": "./src/runtime-server-events.mjs",
    "./terminal-style": "./src/terminal-style.mjs",
    "./package.json": "./package.json",
    "./terminal-rendering": "./src/terminal-rendering.mjs"
  },
  "scripts": {
    "test": "node --test src/*.test.mjs src/agent-cli-pty-e2e.mjs",
    "test:e2e:pty": "node --test src/agent-cli-pty-e2e.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false bin/narada-agent-cli.mjs src/agent-cli.mjs src/nars-attach-client.mjs src/nars-attach-session-machine.mjs src/projected-terminal.mjs src/runtime-server-events.mjs src/session-persistence.mjs src/terminal-style.mjs src/terminal-rendering.mjs"
  },
  "dependencies": {
    "@narada2/carrier-terminal-projection": "workspace:*"
  },
  "devDependencies": {
    "@narada2/agent-runtime-server": "workspace:*",
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.0.0"
  }
}
